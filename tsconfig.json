{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["ES2020"],
    "outDir": "./build"
  },
  "include": ["./src"],
  "exclude": [
    "**/__mocks__/*",
    "**/__tests__/*",
    "./src/ExpoWebSpeechRecognition.ts",
    "./src/ExpoWebSpeechRecognition.web.ts",
    "./src/ExpoSpeechRecognitionModule.web.ts"
  ]
}
