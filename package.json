{
  "name": "expo-speech-recognition",
  "version": "3.1.3",
  "description": "Speech Recognition for standard React Native native-module hosts",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf build",
    "lint": "tsc -p . --noEmit",
    "test": "npm run ts:check",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "release": "npm run build && changeset publish",
    "ts:check": "tsc -p . --noEmit"
  },
  "keywords": [
    "react-native",
    "native-module",
    "ExpoSpeechRecognition",
    "webkitSpeechRecognition",
    "SpeechRecognition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamsch/expo-speech-recognition.git"
  },
  "bugs": {
    "url": "https://github.com/jamsch/expo-speech-recognition/issues"
  },
  "author": "jamsch (https://github.com/jamsch)",
  "license": "MIT",
  "homepage": "https://github.com/jamsch/expo-speech-recognition#readme",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/react": "~19.1.15",
    "globals": "17.1.0",
    "react": "*",
    "react-native": "*",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "prettier": {
    "trailingComma": "all"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
